# Google Maps Platform API key (Places API + Directions API must be enabled).
# Restrict it to this site's HTTP referrer in the Google Cloud Console.
# If unset, the app automatically falls back to the free stack (Nominatim + OSRM) —
# see CLAUDE.md "Key Design Decisions" and src/lib/services/mapConfig.ts.
VITE_GOOGLE_MAPS_API_KEY=

# 'google' (default) or 'free'. Set to 'free' to force Nominatim/OSRM even when
# VITE_GOOGLE_MAPS_API_KEY is set.
VITE_MAP_PROVIDER=google
